        </ol>
      </section>
      <!-- Main content -->

      <section class="content">

        <% transactions.map(data=>{ %>
          <div class="row">
          <div class=" col-md-2 col-lg-3">
          </div>
          <div class="alert alert-success  col-md-8 col-lg-6 text-center text-align" role="alert" style="width:90%;margin-left: 5%;">
            <p>You recieved <%=user.currency%><%=data.amount%>  from <%=data.from%> directly to your <%=data.to%></p>
          </div>
          <div class=" col-md-2 col-lg-3">
          </div>
        </div>

        <%}) %>

        


